extends layout

block content
  h1= title
  
  form(method='POST' action='')
    div.form-group
      label(for='title') Título:
      input#title.form-control(type='text', placeholder='Título do livro', name='title', required)
    
    div.form-group
      label(for='author') Autor:
      input#author.form-control(type='text', placeholder='Autor', name='author', required)
    
    button.btn.btn-primary(type='submit') Enviar
